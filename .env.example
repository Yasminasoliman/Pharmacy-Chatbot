# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/pharmacy_ai

# ── Embeddings ─────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token

# ── LLM provider (choose one) ──────────────────────────────────────────────
# Ollama (local, free)
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_API_KEY=

# OpenAI (vision support – best for OCR)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Gemini (vision support)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
# LLM_API_KEY=AIza...

# ── Pharmacy stock API (leave blank to use built-in mock) ──────────────────
PHARMACY_API_URL=

# ── LangSmith tracing (optional but recommended) ──────────────────────────
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=pharmacy-chatbot

# ── Support contact ────────────────────────────────────────────────────────
PHARMACY_NAME=My Pharmacy
PHARMACY_PHONE=+20-10-XXXX-XXXX
PHARMACY_WORKING_HOURS=Sat-Thu 9 AM – 10 PM

# SMTP (leave blank to skip email delivery)
SUPPORT_EMAIL=support@yourpharmacy.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bot@yourpharmacy.com
SMTP_PASSWORD=your_app_password

# Pharmacy support REST API (leave blank to use local file only)
SUPPORT_API_URL=

